<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="40dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_cog"
                android:layout_marginEnd="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="#FFFFFF"
                android:textSize="26sp"/>
        </LinearLayout>

        <!-- Section: General -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GENERAL"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1e1e1e"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Auto-start on boot"
                android:textColor="#FFFFFF"
                android:textSize="15sp"/>

            <Switch
                android:id="@+id/switch_autostart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2a2a2a"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"/>

        <!-- Section: Display -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DISPLAY"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp"/>

        <!-- World Clock row -->
        <LinearLayout
            android:id="@+id/row_clock"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1e1e1e"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="World Clock"
                android:textColor="#FFFFFF"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/check_clock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓"
                android:textColor="#34d399"
                android:textSize="18sp"
                android:visibility="gone"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2a2a2a"/>

        <!-- Lightning row -->
        <LinearLayout
            android:id="@+id/row_lightning"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1e1e1e"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Lightning"
                android:textColor="#FFFFFF"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/check_lightning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓"
                android:textColor="#fbbf24"
                android:textSize="18sp"
                android:visibility="gone"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2a2a2a"/>

        <!-- Fire row -->
        <LinearLayout
            android:id="@+id/row_fire"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1e1e1e"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Fire"
                android:textColor="#FFFFFF"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/check_fire"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓"
                android:textColor="#fb923c"
                android:textSize="18sp"
                android:visibility="gone"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2a2a2a"/>

        <!-- Marquee Scroll row -->
        <LinearLayout
            android:id="@+id/row_marquee"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1e1e1e"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Marquee Scroll"
                android:textColor="#FFFFFF"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/check_marquee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓"
                android:textColor="#a78bfa"
                android:textSize="18sp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Marquee options panel (shown only when Marquee is selected) -->
        <LinearLayout
            android:id="@+id/panel_marquee"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#181828"
            android:padding="16dp"
            android:visibility="gone">

            <!-- Text label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TEXT"
                android:textColor="#888888"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/et_marquee_text"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="#242435"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="text"
                android:maxLines="1"
                android:hint="Enter message..."
                android:textColorHint="#555566"/>

            <!-- Color label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COLOR"
                android:textColor="#888888"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp"/>

            <!-- Color palette (populated programmatically) -->
            <LinearLayout
                android:id="@+id/ll_colors"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"/>

            <!-- Speed label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SPEED"
                android:textColor="#888888"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_speed_slow"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="SLOW"
                    android:textSize="12sp"
                    android:background="#2a2a2a"
                    android:textColor="#888888"/>

                <Button
                    android:id="@+id/btn_speed_med"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="MED"
                    android:textSize="12sp"
                    android:background="#2a2a2a"
                    android:textColor="#888888"/>

                <Button
                    android:id="@+id/btn_speed_fast"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="FAST"
                    android:textSize="12sp"
                    android:background="#2a2a2a"
                    android:textColor="#888888"/>
            </LinearLayout>

            <!-- Direction label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DIRECTION"
                android:textColor="#888888"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_dir_left"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="← LEFT"
                    android:textSize="11sp"
                    android:background="#2a2a2a"
                    android:textColor="#888888"/>

                <Button
                    android:id="@+id/btn_dir_right"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="RIGHT →"
                    android:textSize="11sp"
                    android:background="#2a2a2a"
                    android:textColor="#888888"/>

                <Button
                    android:id="@+id/btn_dir_up"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="↑ UP"
                    android:textSize="11sp"
                    android:background="#2a2a2a"
                    android:textColor="#888888"/>

                <Button
                    android:id="@+id/btn_dir_down"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="DOWN ↓"
                    android:textSize="11sp"
                    android:background="#2a2a2a"
                    android:textColor="#888888"/>
            </LinearLayout>

            <!-- Blink Text -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Blink Text"
                    android:textColor="#CCCCCC"
                    android:textSize="13sp"/>

                <Switch
                    android:id="@+id/sw_marquee_blink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Border Style -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BORDER STYLE"
                android:textColor="#888888"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_bstyle_off"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:text="OFF"
                    android:textSize="11sp"
                    android:background="#2a2a2a"
                    android:textColor="#888888"/>

                <Button
                    android:id="@+id/btn_bstyle_on"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:text="ON"
                    android:textSize="11sp"
                    android:background="#2a2a2a"
                    android:textColor="#888888"/>

                <Button
                    android:id="@+id/btn_bstyle_dotted"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:text="DOTTED"
                    android:textSize="10sp"
                    android:background="#2a2a2a"
                    android:textColor="#888888"/>

                <Button
                    android:id="@+id/btn_bstyle_snake"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="SNAKE"
                    android:textSize="11sp"
                    android:background="#2a2a2a"
                    android:textColor="#888888"/>
            </LinearLayout>

            <!-- Border Color -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BORDER COLOR"
                android:textColor="#888888"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:id="@+id/ll_border_colors"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"/>

            <Button
                android:id="@+id/btn_brainbow"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="6dp"
                android:text="RAINBOW"
                android:textSize="12sp"
                android:background="#2a2a2a"
                android:textColor="#888888"/>

            <!-- Border Shape -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BORDER SHAPE"
                android:textColor="#888888"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_bshape_dot"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="DOT"
                    android:textSize="12sp"
                    android:background="#2a2a2a"
                    android:textColor="#888888"/>

                <Button
                    android:id="@+id/btn_bshape_star"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="STAR"
                    android:textSize="12sp"
                    android:background="#2a2a2a"
                    android:textColor="#888888"/>

                <Button
                    android:id="@+id/btn_bshape_square"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="SQUARE"
                    android:textSize="11sp"
                    android:background="#2a2a2a"
                    android:textColor="#888888"/>
            </LinearLayout>

        </LinearLayout>
        <!-- end panel_marquee -->

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2a2a2a"/>

        <!-- Crime Eyes row -->
        <LinearLayout
            android:id="@+id/row_crime_eyes"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1e1e1e"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Crime Eyes"
                android:textColor="#FFFFFF"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/check_crime_eyes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓"
                android:textColor="#df4666"
                android:textSize="18sp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Crime Eyes GIF picker panel -->
        <LinearLayout
            android:id="@+id/panel_crime_eyes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1a1010"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECT IMAGE"
                android:textColor="#888888"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_eye1"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="EYE 1"
                    android:textSize="12sp"
                    android:background="#2a2a2a"
                    android:textColor="#888888"/>

                <Button
                    android:id="@+id/btn_eye2"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="EYE 2"
                    android:textSize="12sp"
                    android:background="#2a2a2a"
                    android:textColor="#888888"/>

                <Button
                    android:id="@+id/btn_eye3"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="EYE 3"
                    android:textSize="12sp"
                    android:background="#2a2a2a"
                    android:textColor="#888888"/>
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2a2a2a"/>

        <!-- Blank (Dark) row -->
        <LinearLayout
            android:id="@+id/row_blank"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1e1e1e"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Blank (Dark)"
                android:textColor="#FFFFFF"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/check_blank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓"
                android:textColor="#6b7280"
                android:textSize="18sp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2a2a2a"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"/>

        <!-- Section: About -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ABOUT"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1e1e1e"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Version"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"/>

                <TextView
                    android:id="@+id/tv_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#888888"
                    android:textSize="15sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="App"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Signage for LG Display"
                    android:textColor="#888888"
                    android:textSize="15sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Close button -->
        <Button
            android:id="@+id/btn_close"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="32dp"
            android:text="Close"
            android:textColor="#FFFFFF"
            android:background="#2a2a2a"/>

    </LinearLayout>
</ScrollView>
